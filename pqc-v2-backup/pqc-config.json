{
  "pqc": {
    "version": 2,

    "default": {
      "kem": {
        "enabled": true,
        "mode": "hybrid",
        "algorithm": "ML-KEM-1024",
        "applyTo": ["enveloped", "encrypted"]
      },
      "dsa": {
        "enabled": true,
        "mode": "hybrid",
        "algorithm": "ML-DSA-87",
        "applyTo": ["signed", "detached"]
      },
      "kdf": "HKDF-SHA3-512",
      "sym": "AES-256-GCM"
    },

    "certificates": [
      {
        "id": "cert-legacy-vendor",
        "comment": "PQC 미지원 외부 수신자 — 기존 RSA 유지",
        "kem": { "mode": "classical" },
        "dsa": { "mode": "classical" }
      },
      {
        "id": "cert-internal-hsm",
        "comment": "내부 HSM 서버 — PQC 전용 강화 모드",
        "kem": { "mode": "pqc-only" },
        "dsa": { "mode": "pqc-only" }
      },
      {
        "id": "cert-partner-kem-only",
        "comment": "파트너사 — KEM만 PQC, 서명은 기존 유지",
        "kem": { "mode": "hybrid" },
        "dsa": { "mode": "classical" }
      }
    ]
  }
}
