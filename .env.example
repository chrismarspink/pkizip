# ─────────────────────────────────────────────────────────────────────────────
# PKI Studio v2 — Environment configuration
# Copy to .env and fill in real values before starting:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SoftHSM2 ─────────────────────────────────────────────────────────────────
HSM_TOKEN_LABEL=PKIStudioHSM
HSM_SO_PIN=1234567890
HSM_USER_PIN=12345678

# ── EJBCA ─────────────────────────────────────────────────────────────────────
# MariaDB root password (internal use)
MYSQL_ROOT_PASSWORD=ejbca_root_changeme

# EJBCA application DB password (matches MYSQL_PASSWORD for the ejbca user)
DATABASE_PASSWORD=ejbca_db_changeme

# EJBCA CLI / management password
EJBCA_CLI_DEFAULTPASSWORD=ejbca_cli_changeme

# Port overrides (optional — defaults shown)
EJBCA_HTTP_PORT=8080
EJBCA_HTTPS_PORT=8443

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_admin_changeme

# Keycloak PostgreSQL password (used for both POSTGRES_PASSWORD and KC_DB_PASSWORD)
KC_DB_PASSWORD=keycloak_db_changeme

# Port override (optional)
KEYCLOAK_PORT=8180

# ── Application Database (PostgreSQL) ─────────────────────────────────────────
APP_DB_PASSWORD=pkistudio_db_changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_changeme
REDIS_PORT=6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── TSA ───────────────────────────────────────────────────────────────────────
TSA_PORT=3161
TSA_CERT_CN=PKIStudio TSA
TSA_CERT_ORG=PKIStudio
TSA_CERT_COUNTRY=KR
TSA_POLICY_OID=1.2.3.4.1

# ── FastAPI backend ───────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# PKI_ prefixed settings consumed by pki_studio/shared/config.py
# (pydantic-settings reads these with env_prefix="PKI_")
# ─────────────────────────────────────────────────────────────────────────────

# ── EJBCA REST API ────────────────────────────────────────────────────────────
PKI_EJBCA_BASE_URL=https://ejbca:8443/ejbca/ejbca-rest-api/v1
PKI_EJBCA_CLIENT_CERT_PATH=/certs/ejbca-client.crt
PKI_EJBCA_CLIENT_KEY_PATH=/certs/ejbca-client.key
PKI_EJBCA_CA_NAME=PKIStudioCA
PKI_EJBCA_VERIFY_SSL=false

# ── Keycloak OIDC ─────────────────────────────────────────────────────────────
PKI_KEYCLOAK_URL=http://keycloak:8080
PKI_KEYCLOAK_REALM=pkistudio
PKI_KEYCLOAK_CLIENT_ID=pkistudio-backend
PKI_KEYCLOAK_CLIENT_SECRET=changeme_keycloak_client_secret

# ── HashiCorp Vault (optional) ────────────────────────────────────────────────
PKI_VAULT_URL=http://localhost:8200
PKI_VAULT_TOKEN=

# ── MinIO (app access) ────────────────────────────────────────────────────────
PKI_MINIO_ENDPOINT=minio:9000
PKI_MINIO_ACCESS_KEY=minioadmin
PKI_MINIO_SECRET_KEY=minio_changeme
PKI_MINIO_BUCKET=pki-files

# ── Redis ─────────────────────────────────────────────────────────────────────
PKI_REDIS_URL=redis://:redis_changeme@redis:6379/0

# ── Application Database ──────────────────────────────────────────────────────
PKI_DATABASE_URL=postgresql+asyncpg://pkistudio:pkistudio_db_changeme@app-db:5432/pkistudio

# ── TSA / Crypto ──────────────────────────────────────────────────────────────
PKI_TSA_URL=http://tsa:3161
PKI_CRYPTO_BACKEND=openssl
PKI_SYMMETRIC_ALG=AES-256
PKI_OCSP_CACHE_TTL=3600
